{
  "manifest_version": 3,
  "name": "PW Lecture Downloader",
  "version": "1.0.0",
  "description": "Automatically detect PW lecture videos on any platform and download them in your desired quality.",
  "permissions": [
    "webRequest",
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.pw.live/*",
    "*://*.penpencil.co/*",
    "*://*.classplusapp.com/*",
    "*://*.youtube.com/*",
    "*://chetangupta06-pw-downloader.hf.space/*",
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "PW Lecture Downloader"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
